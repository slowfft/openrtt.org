">from</span><span class=3D"pun">=3D</span><span class=3D"atv">'romeo@monta=
gue.lit/orchard'</span><span class=3D"pln"> </span><span class=3D"atn">type=
</span><span class=3D"pun">=3D</span><span class=3D"atv">'chat'</span><span=
 class=3D"pln"> </span><span class=3D"atn">id</span><span class=3D"pun">=3D=
